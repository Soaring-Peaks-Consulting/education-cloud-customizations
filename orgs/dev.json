{
  "orgName": "education-cloud-customizations - Dev Org",
  "edition": "Developer",
  "features": [ "EducationCloud:5", "DocGen", "DocGenDesigner", "PersonAccounts", "ContactsToMultipleAccounts" ],
  "settings": {
    "lightningExperienceSettings": {
      "enableS1DesktopEnabled": true
    },
    "chatterSettings": {
      "enableChatter": true
    },
    "userManagementSettings": {
      "enableNewProfileUI": true
    },
    "securitySettings": {
      "enableAdminLoginAsAnyUser": true,
      "sessionSettings": {
        "forceRelogin": false
      }
    },
    "communitiesSettings": {
      "enableNetworksEnabled": true,
      "enableOotbProfExtUserOpsEnable": true
    },
    "languageSettings": {
      "enableTranslationWorkbench": true
    },
    "industriesSettings": {
      "enableEducationCloud": true,
      "enableStudentSuccess": true,
      "enableAcademicOperations": true,
      "enableGroupMembershipPref": true,
      "enableEventManagementOrgPref": true,
      "enableMultipleTopicsForShiftsOrgPref": true,
      "enableShareSaWithArOrgPref": true,
      "enableAppFrmAnywhereOrgPref": true
    },
    "OmniStudioSettings": {
      "enableOmniStudioMetadata": true
    }
  }
}