            <dataType>Text</dataType>
            <expression>IF({applicationDecision} == &quot;Admit&quot;, &quot;true&quot;, &quot;&quot;)</expression>
            <length>5</length>
        </expressionFields>
        <expressionFields>
            <alias>isRejected</alias>
            <dataType>Text</dataType>
            <expression>IF({applicationDecision} == &quot;Deny&quot;, &quot;true&quot;, &quot;&quot;)</expression>
